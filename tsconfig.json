{
    "compilerOptions":{
        "module": "esnext", /* ESM output so Parcel can code-split `import()` into separate chunks. */
        "target": "es2020", /* es2020 covers dynamic import(), BigInt, optional chaining and nullish coalescing used across scenes. */
        "moduleResolution": "bundler", /* TS 5.0+ bundler-aware resolver: honors package.json `exports`, doesn't require `.js` suffixes, matches how Parcel actually resolves. Replaces deprecated `node`/`node10`. */
        "paths": {
            /* tsrpc-base-client ships typings at ./index.d.ts but its
             * package.json `exports` field only lists `require` / `import`
             * (no `types` conditional). Under moduleResolution:"bundler" TS
             * strictly follows `exports`, so it can't find the declarations
             * and the inherited methods (callApi/connect/listenMsg) on
             * WsClient end up typed as `any`-placeholder errors in
             * bootstrap.ts. Pin the resolution explicitly here until
             * upstream adds a `types` condition. As of TS 5.0+, `paths`
             * entries are resolved relative to this tsconfig's directory
             * (baseUrl is deprecated), so no baseUrl is needed. */
            "tsrpc-base-client": ["./node_modules/tsrpc-base-client/index.d.ts"]
        },
        // "outDir": "dist",
        // "lib": ["ES5","ES2015.Core"],
        // "declaration": true,
        // "declarationMap": true,
        "strict": false,
        // "experimentalDecorators": true,
        "esModuleInterop": true,
        "skipLibCheck": true,                                /* Skip type checking all .d.ts files. */
        "forceConsistentCasingInFileNames": true,            /* Ensure that casing is correct in imports. */
    }
}
